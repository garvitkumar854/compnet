' Question 4: Explain the data types in VB.NET with a help of a program
Imports System

Module Program
    Sub Main(args As String())

        Dim num As Integer = 10
        Dim price As Double = 99.5
        Dim name As String = "Garvit"
        Dim status As Boolean = True

        Console.WriteLine("Integer = " & num)
        Console.WriteLine("Double = " & price)
        Console.WriteLine("String = " & name)
        Console.WriteLine("Boolean = " & status)

        Console.ReadLine()

    End Sub
End Module
